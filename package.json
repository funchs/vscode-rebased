{
  "name": "vscode-rebased",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "l10n": "./l10n",
  "version": "0.1.4",
  "publisher": "funchs",
  "license": "MIT",
  "icon": "media/icons/rebased.png",
  "galleryBanner": {
    "color": "#3b3b80",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/funchs/vscode-rebased.git"
  },
  "bugs": {
    "url": "https://github.com/funchs/vscode-rebased/issues"
  },
  "homepage": "https://github.com/funchs/vscode-rebased#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "rebase",
    "interactive rebase",
    "log",
    "graph",
    "stash",
    "blame",
    "conventional commits",
    "changelists",
    "local history",
    "jetbrains"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rebased",
          "title": "Rebased",
          "icon": "media/icons/activity-bar.svg"
        }
      ],
      "panel": [
        {
          "id": "rebased-panel",
          "title": "%view.log%",
          "icon": "media/icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "rebased-panel": [
        {
          "id": "rebased.log",
          "name": "%view.log%",
          "type": "webview"
        }
      ],
      "rebased": [
        {
          "id": "rebased.commit",
          "name": "%view.commit%",
          "type": "webview"
        },
        {
          "id": "rebased.stash",
          "name": "%view.stashes%"
        },
        {
          "id": "rebased.branches",
          "name": "%view.branches%"
        },
        {
          "id": "rebased.changelists",
          "name": "%view.changelists%"
        },
        {
          "id": "rebased.submodules",
          "name": "%view.submodules%"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "rebased.rebaseTodo",
        "displayName": "%cmd.rebase.interactive%",
        "selector": [
          {
            "filenamePattern": "**/.git/rebase-merge/git-rebase-todo"
          },
          {
            "filenamePattern": "**/git-rebase-todo"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "rebased.log.refresh",
        "title": "%cmd.log.refresh%",
        "category": "Rebased",
        "icon": "$(refresh)"
      },
      {
        "command": "rebased.log.openPanel",
        "title": "%cmd.log.openPanel%",
        "category": "Rebased",
        "icon": "$(layout-panel)"
      },
      {
        "command": "rebased.log.showBranch",
        "title": "%cmd.log.showBranch%",
        "category": "Rebased",
        "icon": "$(eye)"
      },
      {
        "command": "rebased.commit.refresh",
        "title": "%cmd.commit.refresh%",
        "category": "Rebased",
        "icon": "$(refresh)"
      },
      {
        "command": "rebased.stash.refresh",
        "title": "%cmd.stash.refresh%",
        "category": "Rebased",
        "icon": "$(refresh)"
      },
      {
        "command": "rebased.stash.create",
        "title": "%cmd.stash.create%",
        "category": "Rebased",
        "icon": "$(add)"
      },
      {
        "command": "rebased.stash.apply",
        "title": "%cmd.stash.apply%",
        "category": "Rebased"
      },
      {
        "command": "rebased.stash.pop",
        "title": "%cmd.stash.pop%",
        "category": "Rebased"
      },
      {
        "command": "rebased.stash.drop",
        "title": "%cmd.stash.drop%",
        "category": "Rebased",
        "icon": "$(trash)"
      },
      {
        "command": "rebased.cherryPick",
        "title": "%cmd.cherryPick%",
        "category": "Rebased"
      },
      {
        "command": "rebased.rebase.interactive",
        "title": "%cmd.rebase.interactive%",
        "category": "Rebased"
      },
      {
        "command": "rebased.branch.checkout",
        "title": "%cmd.branch.checkout%",
        "category": "Rebased"
      },
      {
        "command": "rebased.branch.create",
        "title": "%cmd.branch.create%",
        "category": "Rebased",
        "icon": "$(add)"
      },
      {
        "command": "rebased.branch.merge",
        "title": "%cmd.branch.merge%",
        "category": "Rebased",
        "icon": "$(git-merge)"
      },
      {
        "command": "rebased.branch.rebaseOnto",
        "title": "%cmd.branch.rebaseOnto%",
        "category": "Rebased"
      },
      {
        "command": "rebased.branch.rename",
        "title": "%cmd.branch.rename%",
        "category": "Rebased",
        "icon": "$(pencil)"
      },
      {
        "command": "rebased.branch.delete",
        "title": "%cmd.branch.delete%",
        "category": "Rebased",
        "icon": "$(trash)"
      },
      {
        "command": "rebased.branch.newFromHere",
        "title": "%cmd.branch.newFromHere%",
        "category": "Rebased",
        "icon": "$(add)"
      },
      {
        "command": "rebased.branch.pushSetUpstream",
        "title": "%cmd.branch.pushSetUpstream%",
        "category": "Rebased",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "rebased.branch.pushForce",
        "title": "%cmd.branch.pushForce%",
        "category": "Rebased",
        "icon": "$(zap)"
      },
      {
        "command": "rebased.branch.fetch",
        "title": "%cmd.branch.fetch%",
        "category": "Rebased",
        "icon": "$(cloud-download)"
      },
      {
        "command": "rebased.branch.deleteRemote",
        "title": "%cmd.branch.deleteRemote%",
        "category": "Rebased",
        "icon": "$(trash)"
      },
      {
        "command": "rebased.branch.resetTo",
        "title": "%cmd.branch.resetTo%",
        "category": "Rebased",
        "icon": "$(discard)"
      },
      {
        "command": "rebased.branch.copyName",
        "title": "%cmd.branch.copyName%",
        "category": "Rebased",
        "icon": "$(copy)"
      },
      {
        "command": "rebased.commit.amend",
        "title": "%cmd.commit.amend%",
        "category": "Rebased"
      },
      {
        "command": "rebased.reflog.open",
        "title": "%cmd.reflog.open%",
        "category": "Rebased",
        "icon": "$(history)"
      },
      {
        "command": "rebased.hunks.open",
        "title": "%cmd.hunks.open%",
        "category": "Rebased"
      },
      {
        "command": "rebased.conflict.show",
        "title": "%cmd.conflict.show%",
        "category": "Rebased"
      },
      {
        "command": "rebased.commit.show",
        "title": "%cmd.commit.show%",
        "category": "Rebased"
      },
      {
        "command": "rebased.branches.pick",
        "title": "%cmd.branches.pick%",
        "category": "Rebased",
        "icon": "$(git-branch)"
      },
      {
        "command": "rebased.file.history",
        "title": "%cmd.file.history%",
        "category": "Rebased"
      },
      {
        "command": "rebased.branch.compare",
        "title": "%cmd.branch.compare%",
        "category": "Rebased"
      },
      {
        "command": "rebased.tags.pick",
        "title": "%cmd.tags.pick%",
        "category": "Rebased",
        "icon": "$(tag)"
      },
      {
        "command": "rebased.blame.toggleGutter",
        "title": "%cmd.blame.toggleGutter%",
        "category": "Rebased"
      },
      {
        "command": "rebased.push",
        "title": "%cmd.push%",
        "category": "Rebased",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "rebased.pull",
        "title": "%cmd.pull%",
        "category": "Rebased",
        "icon": "$(cloud-download)"
      },
      {
        "command": "rebased.commit.search",
        "title": "%cmd.commit.search%",
        "category": "Rebased",
        "icon": "$(search)"
      },
      {
        "command": "rebased.remotes.pick",
        "title": "%cmd.remotes.pick%",
        "category": "Rebased",
        "icon": "$(cloud)"
      },
      {
        "command": "rebased.changelist.create",
        "title": "%cmd.changelist.create%",
        "category": "Rebased",
        "icon": "$(add)"
      },
      {
        "command": "rebased.changelist.rename",
        "title": "%cmd.changelist.rename%",
        "category": "Rebased"
      },
      {
        "command": "rebased.changelist.delete",
        "title": "%cmd.changelist.delete%",
        "category": "Rebased",
        "icon": "$(trash)"
      },
      {
        "command": "rebased.changelist.setActive",
        "title": "%cmd.changelist.setActive%",
        "category": "Rebased"
      },
      {
        "command": "rebased.changelist.commit",
        "title": "%cmd.changelist.commit%",
        "category": "Rebased",
        "icon": "$(check)"
      },
      {
        "command": "rebased.changelist.moveFile",
        "title": "%cmd.changelist.moveFile%",
        "category": "Rebased"
      },
      {
        "command": "rebased.changelist.refresh",
        "title": "%cmd.changelist.refresh%",
        "category": "Rebased",
        "icon": "$(refresh)"
      },
      {
        "command": "rebased.localHistory.show",
        "title": "%cmd.localHistory.show%",
        "category": "Rebased"
      },
      {
        "command": "rebased.submodule.init",
        "title": "%cmd.submodule.init%",
        "category": "Rebased"
      },
      {
        "command": "rebased.submodule.update",
        "title": "%cmd.submodule.update%",
        "category": "Rebased"
      },
      {
        "command": "rebased.submodule.sync",
        "title": "%cmd.submodule.sync%",
        "category": "Rebased"
      },
      {
        "command": "rebased.submodule.refresh",
        "title": "%cmd.submodule.refresh%",
        "category": "Rebased",
        "icon": "$(refresh)"
      },
      {
        "command": "rebased.commit.wizard",
        "title": "%cmd.commit.wizard%",
        "category": "Rebased",
        "icon": "$(edit)"
      },
      {
        "command": "rebased.updateProject",
        "title": "%cmd.updateProject%",
        "category": "Rebased",
        "icon": "$(sync)"
      },
      {
        "command": "rebased.diagnose",
        "title": "%cmd.diagnose%",
        "category": "Rebased",
        "icon": "$(pulse)"
      },
      {
        "command": "rebased.showOutput",
        "title": "%cmd.showOutput%",
        "category": "Rebased",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rebased.log.refresh",
          "when": "view == rebased.log",
          "group": "navigation"
        },
        {
          "command": "rebased.commit.refresh",
          "when": "view == rebased.commit",
          "group": "navigation"
        },
        {
          "command": "rebased.stash.refresh",
          "when": "view == rebased.stash",
          "group": "navigation"
        },
        {
          "command": "rebased.stash.create",
          "when": "view == rebased.stash",
          "group": "navigation"
        },
        {
          "command": "rebased.branch.create",
          "when": "view == rebased.branches",
          "group": "navigation"
        },
        {
          "command": "rebased.reflog.open",
          "when": "view == rebased.log",
          "group": "navigation@9"
        },
        {
          "command": "rebased.branches.pick",
          "when": "view == rebased.branches",
          "group": "navigation@1"
        },
        {
          "command": "rebased.tags.pick",
          "when": "view == rebased.branches",
          "group": "navigation@2"
        },
        {
          "command": "rebased.commit.search",
          "when": "view == rebased.log",
          "group": "navigation@1"
        },
        {
          "command": "rebased.updateProject",
          "when": "view == rebased.commit",
          "group": "navigation@0"
        },
        {
          "command": "rebased.push",
          "when": "view == rebased.commit",
          "group": "navigation@1"
        },
        {
          "command": "rebased.pull",
          "when": "view == rebased.commit",
          "group": "navigation@2"
        },
        {
          "command": "rebased.changelist.create",
          "when": "view == rebased.changelists",
          "group": "navigation@1"
        },
        {
          "command": "rebased.changelist.refresh",
          "when": "view == rebased.changelists",
          "group": "navigation@2"
        },
        {
          "command": "rebased.submodule.init",
          "when": "view == rebased.submodules",
          "group": "navigation@1"
        },
        {
          "command": "rebased.submodule.update",
          "when": "view == rebased.submodules",
          "group": "navigation@2"
        },
        {
          "command": "rebased.submodule.refresh",
          "when": "view == rebased.submodules",
          "group": "navigation@3"
        }
      ],
      "explorer/context": [
        {
          "command": "rebased.file.history",
          "when": "resourceScheme == file",
          "group": "1_rebased@1"
        },
        {
          "command": "rebased.localHistory.show",
          "when": "resourceScheme == file",
          "group": "1_rebased@2"
        }
      ],
      "editor/context": [
        {
          "command": "rebased.file.history",
          "when": "resourceScheme == file",
          "group": "1_rebased@1"
        },
        {
          "command": "rebased.localHistory.show",
          "when": "resourceScheme == file",
          "group": "1_rebased@2"
        }
      ],
      "view/item/context": [
        {
          "command": "rebased.stash.apply",
          "when": "view == rebased.stash && viewItem == stash",
          "group": "1_actions@1"
        },
        {
          "command": "rebased.stash.pop",
          "when": "view == rebased.stash && viewItem == stash",
          "group": "1_actions@2"
        },
        {
          "command": "rebased.stash.drop",
          "when": "view == rebased.stash && viewItem == stash",
          "group": "9_danger@1"
        },
        {
          "command": "rebased.branch.checkout",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote)",
          "group": "1_actions@1"
        },
        {
          "command": "rebased.branch.merge",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote)",
          "group": "1_actions@2"
        },
        {
          "command": "rebased.branch.rebaseOnto",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote)",
          "group": "1_actions@3"
        },
        {
          "command": "rebased.branch.compare",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote)",
          "group": "2_inspect@1"
        },
        {
          "command": "rebased.branch.newFromHere",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote || viewItem == branch-current)",
          "group": "2_inspect@2"
        },
        {
          "command": "rebased.branch.rename",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-current)",
          "group": "3_edit@1"
        },
        {
          "command": "rebased.branch.pushSetUpstream",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-current)",
          "group": "3_edit@2"
        },
        {
          "command": "rebased.branch.fetch",
          "when": "view == rebased.branches && viewItem == branch-remote",
          "group": "1_actions@4"
        },
        {
          "command": "rebased.branch.copyName",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote || viewItem == branch-current)",
          "group": "2_inspect@3"
        },
        {
          "command": "rebased.branch.pushForce",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-current)",
          "group": "3_edit@3"
        },
        {
          "command": "rebased.branch.resetTo",
          "when": "view == rebased.branches && (viewItem == branch-local || viewItem == branch-remote)",
          "group": "9_danger@0"
        },
        {
          "command": "rebased.branch.delete",
          "when": "view == rebased.branches && viewItem == branch-local",
          "group": "9_danger@1"
        },
        {
          "command": "rebased.branch.deleteRemote",
          "when": "view == rebased.branches && viewItem == branch-remote",
          "group": "9_danger@2"
        },
        {
          "command": "rebased.changelist.commit",
          "when": "view == rebased.changelists && viewItem =~ /changelist/",
          "group": "1_actions@1"
        },
        {
          "command": "rebased.changelist.setActive",
          "when": "view == rebased.changelists && viewItem == changelist",
          "group": "1_actions@2"
        },
        {
          "command": "rebased.changelist.rename",
          "when": "view == rebased.changelists && viewItem =~ /changelist/",
          "group": "2_edit@1"
        },
        {
          "command": "rebased.changelist.delete",
          "when": "view == rebased.changelists && viewItem == changelist",
          "group": "9_danger@1"
        },
        {
          "command": "rebased.changelist.moveFile",
          "when": "view == rebased.changelists && viewItem == changelist-file",
          "group": "1_actions@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rebased.commit.amend",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      },
      {
        "command": "rebased.branches.pick",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "rebased.file.history",
        "key": "ctrl+alt+h",
        "mac": "cmd+alt+h",
        "when": "editorTextFocus"
      },
      {
        "command": "rebased.blame.toggleGutter",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus"
      },
      {
        "command": "rebased.commit.search",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "rebased.commit.wizard",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c"
      },
      {
        "command": "rebased.updateProject",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "configuration": {
      "title": "Rebased",
      "properties": {
        "rebased.log.maxCommits": {
          "type": "number",
          "default": 2000,
          "description": "%cfg.log.maxCommits%"
        },
        "rebased.log.allBranches": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.log.allBranches%"
        },
        "rebased.rebase.autoStash": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.rebase.autoStash%"
        },
        "rebased.gitPath": {
          "type": "string",
          "default": "git",
          "description": "%cfg.gitPath%"
        },
        "rebased.blame.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.blame.enabled%"
        },
        "rebased.localHistory.maxPerFile": {
          "type": "number",
          "default": 50,
          "description": "%cfg.localHistory.maxPerFile%"
        },
        "rebased.localHistory.maxBytes": {
          "type": "number",
          "default": 1048576,
          "description": "%cfg.localHistory.maxBytes%"
        },
        "rebased.updateProject.strategy": {
          "type": "string",
          "enum": [
            "ask",
            "rebase",
            "merge"
          ],
          "enumDescriptions": [
            "%cfg.updateProject.strategy.ask%",
            "%cfg.updateProject.strategy.rebase%",
            "%cfg.updateProject.strategy.merge%"
          ],
          "default": "ask",
          "description": "%cfg.updateProject.strategy%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "compile": "tsc --noEmit",
    "test": "node scripts/smoke-test.mjs && node scripts/integration-test.mjs && node scripts/edge-cases-test.mjs && node scripts/cc-test.mjs && node scripts/notify-test.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
